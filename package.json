{
  "name": "pobres-pandas",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": "24.15.0",
    "pnpm": ">=10.0.0 <11"
  },
  "scripts": {
    "audit:dependencies": "pnpm audit --audit-level=high",
    "build": "tsc --noEmit && vite build",
    "dev": "vite",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "preview": "vite preview",
    "release:prepare": "node scripts/create-release-output.mjs",
    "release:serve": "serve .vercel/output/static --listen 4173 --no-clipboard --no-port-switching",
    "release:verify": "node scripts/verify-release-archive.mjs",
    "smoke:release": "node scripts/smoke-release.mjs",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit --pretty false",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm build && pnpm test:e2e",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.10.13",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "prettier": "3.9.5",
    "serve": "14.2.6",
    "tar-stream": "3.2.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.64.0",
    "vercel": "56.0.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "@vercel/backends>path-to-regexp": "8.4.2",
      "@vercel/express>path-to-regexp": "8.4.2",
      "@vercel/fun>path-to-regexp": "8.4.2",
      "@vercel/fun>tar": "7.5.20",
      "@vercel/fun>@tootallnate/once": "2.0.1",
      "@vercel/hono>path-to-regexp": "8.4.2",
      "@vercel/node>undici": "6.27.0",
      "@vercel/python-analysis>js-yaml": "4.3.0",
      "@vercel/python-analysis>minimatch": "10.2.5",
      "@vercel/python-analysis>smol-toml": "1.6.1",
      "@vercel/rust>smol-toml": "1.6.1",
      "@vercel/static-config>ajv": "8.18.0",
      "vercel>smol-toml": "1.6.1",
      "vercel>undici": "6.27.0"
    }
  }
}
